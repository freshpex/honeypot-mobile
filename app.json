{
  "expo": {
    "name": "HoneyPot",
    "slug": "honeypot-mobile",
    "scheme": "honeypot",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./public/playstore-icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "icon": "./public/icon-20.png",
      "bundleIdentifier": "com.honeypot.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./public/ic_launcher_foreground.png",
        "backgroundImage": "./public/ic_launcher_background.png"
      },
      "package": "com.honeypot.mobile"
    },
    "extra": {
      "router": {
        "root": "src/routes"
      },
      "eas": {
        "projectId": "05cecb14-4c0a-4ad9-ab1b-da596268b954"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./public/playstore-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FAF9F8"
        }
      ],
      "@react-native-google-signin/google-signin"
    ]
  }
}
